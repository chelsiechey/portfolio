<h1>Education</h1>
    <div class="black-links">
        <div class="row">
            <% @educations.each do |edu| %>
                <div class="col s12">
                    <div class="card project-card">
                        <div class="card-content">
                            <% if admin_signed_in? %>
                                <span class="card-title"><%= link_to edu.school, edu %></span>
                            <% else %>
                                <span class="card-title"><%= edu.school %></span>
                            <% end %>
                            <p><%= edu.description %></p>
                            <br />
                        </div>
                        <div class="card-action">
                            <a href="http://www.google.com" target="_blank" class="black-text"><image src="/assets/github.svg" alt="github"></a>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>

    <% if admin_signed_in? %>
        <%= link_to 'Add Education', new_education_path %>
    <% end %>
    </div>
