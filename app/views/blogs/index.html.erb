<h1>Follow My Learning Experience</h1>
<% @blogs.each do |b| %>
    <% if admin_signed_in? %>
        <h3><%= link_to b.title, b %></h3>
    <% else %>
        <h3><%= b.title %></h3>
    <% end %>
    <p><%= b.content %></p>
<% end %>
<% if admin_signed_in? %>
    <%= link_to 'Add Blog Post', new_blog_path %>
<% end %>

